layout {
    pane size=1 borderless=true {
        plugin location="tab-bar"
    }
    pane split_direction="vertical" {
        pane size="33%" split_direction="horizontal" {
            pane name="cmd"
            pane size="15%" name="agents" {
                command "mob"
                args "cat"
            }
        }
        pane split_direction="horizontal" {
            pane size="50%" split_direction="vertical" {
                pane name="claude-1" {
                    command "claude"
                }
                pane name="claude-2" {
                    command "claude"
                }
            }
            pane name="diffs" {
                command "lumen"
                args "diff" "--watch"
            }
        }
    }
    pane size=2 borderless=true {
        plugin location="status-bar"
    }
}
