layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="status-bar"
        }
    }
    tab name="cockpit" focus=true {
        pane command="bash" {
            args "-ic" "watch -n 5 'git worktree list'"
        }
        pane command="npx" {
            args "ccusage@latest"
        }
    }
    tab name="auth" {
        pane command="claude" {
            cwd "../myapp-auth"
        }
    }
    tab name="payments" {
        pane command="claude" {
            cwd "../myapp-payments"
        }
    }
    tab name="dashboard" {
        pane command="claude" {
            cwd "../myapp-dashboard"
        }
    }
}
